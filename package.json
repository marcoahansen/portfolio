{
  "name": "portfolio",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "prebuild": "pnpm run check:assets && pnpm run check:i18n",
    "check:assets": "node --import tsx scripts/check-assets.ts",
    "check:i18n": "node --import tsx scripts/check-i18n.ts",
    "start": "react-router-serve ./build/server/index.js",
    "preview": "vite preview",
    "typecheck": "react-router typegen && tsc --noEmit",
    "lint": "react-router typegen && eslint . --max-warnings=0",
    "lint:fix": "react-router typegen && eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@emailjs/browser": "^4.4",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource/asimovian": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-router/node": "^7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.2.0",
    "isbot": "^5",
    "lucide-react": "^1.14.0",
    "react": "^19",
    "react-dom": "^19",
    "react-i18next": "^17.0.8",
    "react-router": "^7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.48",
    "@react-router/dev": "^7",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.7.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4",
    "axe-core": "^4.11.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^15",
    "postcss": "^8.4",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.4",
    "tsx": "^4.20.0",
    "typescript": "^5.6",
    "typescript-eslint": "^8.59.3",
    "vite": "^6",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1",
    "vitest-axe": "^0.1.0"
  }
}
